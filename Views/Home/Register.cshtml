@{
    ViewData["Title"] = "Register";
}

<div class="auth-page">
    @if (TempData["Message"] != null)
    {
        <div class="popup @TempData["Type"]">
            @TempData["Message"]
        </div>
    }

    <div class="auth-card">
        <div class="brand">
            <span></span>
            <h1>Create Account</h1>
        </div>

        <p class="tagline">Register to continue</p>

        <form method="post" action="/Home/Register">
            <div class="field">
                <label>Name</label>
                <input type="text" name="name" placeholder="Enter your name" required />
            </div>

            <div class="field">
                <label>Email</label>
                <input type="email" name="email" placeholder="Enter your email" required />
            </div>

            <div class="field">
                <label>Password</label>
                <input type="password" name="password" placeholder="Create password" required />
            </div>

            <button type="submit">Register</button>
            <div class="redirectLink">Already have an account? <a href="/Home/Login"><span class="link">Login Now</span></a></div>
        </form>
    </div>
</div>